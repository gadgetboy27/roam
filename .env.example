# ── Server ─────────────────────────────────────────────
NODE_ENV=production
PORT=5000
SESSION_SECRET=change-me-to-a-long-random-string

# ── Database (Supabase Postgres) ────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# ── Supabase ────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Vite (public — exposed to browser) ─────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PAYMENT_WEBHOOK_SECRET=whsec_...
STRIPE_IDENTITY_WEBHOOK_SECRET=whsec_...
STRIPE_ADVENTURER_PRICE_ID=price_...
STRIPE_BOOST_PRICE_ID=price_...
STRIPE_ORGANISER_PRICE_ID=price_...

# ── Email (Resend) ──────────────────────────────────────
RESEND_API_KEY=re_...

# ── Admin ───────────────────────────────────────────────
ADMIN_EMAILS=admin@letsroam.life

# ── App URL (used in Stripe redirect & Facebook callback) ─
APP_URL=https://letsroam.life

# ── Optional: Facebook OAuth ────────────────────────────
FACEBOOK_APP_SECRET=
