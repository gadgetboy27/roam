# ── Server ─────────────────────────────────────────────
NODE_ENV=production
PORT=5000
SESSION_SECRET=change-me-to-a-long-random-string

# ── Database (Supabase Postgres) ────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# ── Supabase ────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Vite (public — exposed to browser) ─────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Stripe ──────────────────────────────────────────────
# Only the secret key + webhook secrets are required. A restricted key
# (rk_live_...) works too, as long as it can write Checkout Sessions and
# Identity VerificationSessions. Identity must be enabled on the account
# for the "Verify" flow to work.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PAYMENT_WEBHOOK_SECRET=whsec_...
STRIPE_IDENTITY_WEBHOOK_SECRET=whsec_...
# NOTE: the *_PRICE_ID vars below are NOT used by the app. Checkout builds
# its prices inline via Stripe `price_data` (see server/routes/payments.routes.ts:
# Adventurer $5/mo, Boost $5 one-time, Organiser $20 one-time). No Stripe
# Products/Prices need to be created. Left here only for reference.
STRIPE_ADVENTURER_PRICE_ID=price_...
STRIPE_BOOST_PRICE_ID=price_...
STRIPE_ORGANISER_PRICE_ID=price_...

# ── Email (Resend) ──────────────────────────────────────
RESEND_API_KEY=re_...

# ── Admin ───────────────────────────────────────────────
ADMIN_EMAILS=admin@letsroam.life

# ── Social posting (Ayrshare) — used by scripts/post-to-social.mjs ──
# Only needed locally to post to FB/IG/LinkedIn; NOT required by the server.
AYRSHARE_API_KEY=

# ── App URL (used in Stripe redirect & Facebook callback) ─
APP_URL=https://letsroam.life

# ── Optional: Facebook OAuth ────────────────────────────
FACEBOOK_APP_SECRET=
